{
  "name": "que-hay-pa-hacer-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.0",
  "engines": {
    "node": "22.14.0",
    "pnpm": "10.6.0"
  },
  "scripts": {
    "preinstall": "node ./scripts/enforce-pnpm.cjs",
    "prepare": "husky",
    "check:runtime": "node ./scripts/check-runtime.cjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint-staged": "lint-staged",
    "test": "pnpm -r run test --if-present",
    "build": "pnpm -r run build --if-present",
    "docker:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml down"
  },
  "devDependencies": {
    "@eslint/js": "9.21.0",
    "eslint": "9.21.0",
    "husky": "9.1.7",
    "lint-staged": "15.4.3",
    "prettier": "3.5.3"
  }
}
